@model FuenteDeVida.EN.Factura

@{
    ViewData["Title"] = "Delete";
}

<h1>Eliminar Factura</h1>

<h3>¿Está seguro que desea eliminar este registro?</h3>

<div>
    <hr />
    <dl class="row">

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IdFactura)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IdFactura)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FechaEmision)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FechaEmision)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Total)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Total)
        </dd>

    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="IdFactura" />

        <input type="submit" value="ELIMINAR" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-dark">CANCELAR</a>
    </form>

</div>