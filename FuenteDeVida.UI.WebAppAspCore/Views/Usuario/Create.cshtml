                <label asp-for="IdRol" class="control-label"></label>
                <input asp-for="IdRol" class="form-control" />
                <span asp-validation-for="IdRol" class="text-danger"></span>
            </div>
            </div> *@

    </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="IdRol" class="control-label"></label>
                    <select asp-for="IdRol" class="form-control">
                        <option selected value="">SELECCIONAR</option>
                        @foreach (var item in roles)
                        {
                            <option value="@item.IdRol">@item.NombreRol</option>
                        }
                    </select>
                    <span asp-validation-for="IdRol" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
            <div class="form-group mt-2">
                <input type="submit" value="GUARDAR" class="btn btn-primary" />
                <a asp-action="Index" class=" btn btn-dark">CANCELAR</a>
            </div>
            <span class="text-danger">@ViewBag.Error</span>
        </div>
    </div>

</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
