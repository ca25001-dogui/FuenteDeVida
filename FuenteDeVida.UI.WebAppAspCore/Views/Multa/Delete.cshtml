@model FuenteDeVida.EN.Multa

@{
    ViewData["Title"] = "Delete";
}

<h1>Eliminar Multa</h1>

<h3>¿Esta seguro de eliminar una multa?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IdMulta)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IdMulta)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Monto)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Monto)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FechaVencimiento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FechaVencimiento)
        </dd>
       @*  <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Top_Aux)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Top_Aux)
        </dd> *@
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IdComunidad)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IdComunidad)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="IdMulta" />
        <button type="submit" class="btn btn-danger">ELIMINAR</button>
        <a asp-action="Index" class=" btn btn-dark">CANCELAR</a>
    </form>
    <span class=" text-danger">@ViewBag.Error</span>
</div>
